def get_scaffold(smiles):
    try:
        mol = Chem.MolFromSmiles(smiles)
        if mol is None:
            return None
        scaffold = MurckoScaffold.MurckoScaffoldSmiles(mol=mol, includeChirality=False)
        return scaffold
    except:
        return None


def scaffold_split(df, smiles_col='smiles', frac_train=0.8, frac_valid=0.1, frac_test=0.1, seed=42):
    """Split dataset by Bemis-Murcko scaffold, assigning scaffold groups one-by-one
    to whichever split is most under its target size (greedy balanced assignment)."""
    scaffolds = defaultdict(list)
    for idx, smiles in enumerate(df[smiles_col]):
        scaffold = get_scaffold(smiles)
        if scaffold is not None:
            scaffolds[scaffold].append(idx)

    scaffold_sets = sorted(scaffolds.values(), key=lambda x: len(x), reverse=True)

    rng = np.random.RandomState(seed)
    # shuffle order among equally-sized groups for randomness, but keep big-first bias
    scaffold_sets = sorted(scaffold_sets, key=lambda x: (-len(x), rng.random()))

    n_total = sum(len(s) for s in scaffold_sets)
    train_target = frac_train * n_total
    valid_target = frac_valid * n_total
    test_target = frac_test * n_total

    train_idx, valid_idx, test_idx = [], [], []

    for s in scaffold_sets:
        # assign to whichever split is furthest below its target (proportionally)
        train_def = train_target - len(train_idx)
        valid_def = valid_target - len(valid_idx)
        test_def = test_target - len(test_idx)

        choice = max([('train', train_def), ('valid', valid_def), ('test', test_def)],
                     key=lambda x: x[1])[0]

        if choice == 'train':
            train_idx += s
        elif choice == 'valid':
            valid_idx += s
        else:
            test_idx += s

    return train_idx, valid_idx, test_idx


