# ---- PBES helper functions (Cell 12, 13, 13b) ----
class SingleGraphWrapper(nn.Module):
    def __init__(self, base_model, task_idx):
        super().__init__()
        self.base_model = base_model
        self.task_idx = task_idx
    def forward(self, x, edge_index):
        batch = torch.zeros(x.size(0), dtype=torch.long, device=x.device)
        out = self.base_model(x, edge_index, batch)
        return out[:, self.task_idx:self.task_idx+1]

def mol_to_pyg_data(mol):
    atom_features = [get_atom_features(atom) for atom in mol.GetAtoms()]
    x = torch.tensor(atom_features, dtype=torch.float)
    edge_indices, edge_features = [], []
    for bond in mol.GetBonds():
        i, j = bond.GetBeginAtomIdx(), bond.GetEndAtomIdx()
        bf = get_bond_features(bond)
        edge_indices += [[i, j], [j, i]]
        edge_features += [bf, bf]
    if len(edge_indices) == 0:
        edge_indices = [[0, 0]]
        edge_features = [[0, 0, 0, 0, 0, 0]]
    edge_index = torch.tensor(edge_indices, dtype=torch.long).t().contiguous()
    edge_attr = torch.tensor(edge_features, dtype=torch.float)
    return Data(x=x, edge_index=edge_index, edge_attr=edge_attr)

def generate_isomorphic_variants(smiles, K=10, seed=42):
    base_mol = Chem.MolFromSmiles(smiles)
    if base_mol is None:
        return [], 0, {}, 0
    n_atoms = base_mol.GetNumAtoms()
    rng = np.random.RandomState(seed)
    base_canonical = Chem.MolToSmiles(base_mol)
    variants = [(list(range(n_atoms)), base_mol)]
    seen_orders = {tuple(range(n_atoms))}
    attempts = 0
    max_attempts = K * 50
    fail_reasons = {'duplicate': 0, 'renumber_error': 0, 'smiles_mismatch': 0}
    while len(variants) < K and attempts < max_attempts:
        attempts += 1
        perm = [int(i) for i in rng.permutation(n_atoms)]
        perm_tuple = tuple(perm)
        if perm_tuple in seen_orders:
            fail_reasons['duplicate'] += 1
            continue
        seen_orders.add(perm_tuple)
        try:
            renumbered_mol = Chem.RenumberAtoms(base_mol, perm)
            check_smiles = Chem.MolToSmiles(renumbered_mol)
        except Exception:
            fail_reasons['renumber_error'] += 1
            continue
        if check_smiles == base_canonical:
            variants.append((perm, renumbered_mol))
        else:
            fail_reasons['smiles_mismatch'] += 1
    return variants, attempts, fail_reasons, n_atoms

def realign_to_original_order(importance, perm):
    n = len(perm)
    realigned = np.zeros(n)
    for variant_pos, original_idx in enumerate(perm):
        realigned[original_idx] = importance[variant_pos]
    return realigned

def get_node_importance(mol, model, task_idx, device, epochs=200):
    data = mol_to_pyg_data(mol).to(device)
    wrapped = SingleGraphWrapper(model, task_idx).to(device)
    wrapped.eval()
    exp = Explainer(
        model=wrapped,
        algorithm=GNNExplainer(epochs=epochs),
        explanation_type='model',
        node_mask_type='attributes',
        edge_mask_type='object',
        model_config=dict(mode='regression', task_level='graph', return_type='raw'),
    )
    explanation = exp(data.x, data.edge_index)
    return explanation.node_mask.sum(dim=1).cpu().detach().numpy()

def compute_pbes_acs(smiles, model, task_idx, device, K=10, gnn_epochs=200, seed=42):
    variants, attempts, fail_reasons, n_atoms = generate_isomorphic_variants(smiles, K=K, seed=seed)
    if len(variants) < 2 or n_atoms < 3:
        return None, None, False
    realigned_attributions = []
    for perm, mol in variants:
        try:
            imp = get_node_importance(mol, model, task_idx, device, epochs=gnn_epochs)
            realigned_attributions.append(realign_to_original_order(imp, perm))
        except Exception:
            continue
    if len(realigned_attributions) < 2:
        return None, None, False
    realigned_attributions = np.array(realigned_attributions)
    K_actual = realigned_attributions.shape[0]
    correlations = []
    for i in range(K_actual):
        for j in range(i + 1, K_actual):
            rho, _ = spearmanr(realigned_attributions[i], realigned_attributions[j])
            if not np.isnan(rho):
                correlations.append(rho)
    if len(correlations) == 0:
        return None, None, False
    return np.mean(correlations), realigned_attributions, True

