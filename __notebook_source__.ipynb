def df_to_graphs(df, indices, tasks):
    graphs = []
    skipped = 0
    for idx in indices:
        row = df.iloc[idx]
        smiles = row['smiles']
        labels = []
        for t in tasks:
            val = row[t]
            labels.append(-1.0 if pd.isna(val) else float(val))
        graph = smiles_to_graph(smiles, labels=labels)
        if graph is None or graph.x.shape[0] == 0:
            skipped += 1
            continue
        graphs.append(graph)
    print(f"  Converted {len(graphs)} molecules, skipped {skipped} invalid SMILES")
    return graphs

