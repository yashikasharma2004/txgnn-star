print(f"✅ Importance score range: [{node_importance.min():.4f}, {node_importance.max():.4f}]")


# CELL 13 (Fixed) - Purpose: Generate K=10 graph-isomorphism-preserving variants with debug visibility

def generate_isomorphic_variants(smiles, K=10, seed=42):
    base_mol = Chem.MolFromSmiles(smiles)
    if base_mol is None:
        return []

    n_atoms = base_mol.GetNumAtoms()
    rng = np.random.RandomState(seed)
    base_canonical = Chem.MolToSmiles(base_mol)

    variants = [(list(range(n_atoms)), base_mol)]
    seen_orders = {tuple(range(n_atoms))}

    attempts = 0
    max_attempts = K * 50
    fail_reasons = {'duplicate': 0, 'renumber_error': 0, 'smiles_mismatch': 0}

    while len(variants) < K and attempts < max_attempts:
        attempts += 1
        perm = list(rng.permutation(n_atoms))
        perm_tuple = tuple(perm)
        if perm_tuple in seen_orders:
            fail_reasons['duplicate'] += 1
            continue
        seen_orders.add(perm_tuple)

        try:
            renumbered_mol = Chem.RenumberAtoms(base_mol, perm)
        except Exception as e:
            fail_reasons['renumber_error'] += 1
            continue

        try:
            check_smiles = Chem.MolToSmiles(renumbered_mol)
        except Exception:
            fail_reasons['renumber_error'] += 1
            continue

        if check_smiles == base_canonical:
            variants.append((perm, renumbered_mol))
        else:
            fail_reasons['smiles_mismatch'] += 1

    return variants, attempts, fail_reasons, n_atoms


