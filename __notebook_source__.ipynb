# CELL 8 - Purpose: Define evaluation function that computes per-task and mean ROC-AUC / PR-AUC, ignoring missing labels

def evaluate(model, loader, device, tasks):
    model.eval()
    all_logits = []
    all_labels = []

    with torch.no_grad():
        for batch in loader:
            batch = batch.to(device)
            out = model(batch.x, batch.edge_index, batch.batch)
            all_logits.append(out.cpu())
            all_labels.append(batch.y.cpu())

    all_logits = torch.cat(all_logits, dim=0)
    all_labels = torch.cat(all_labels, dim=0)
    all_probs = torch.sigmoid(all_logits).numpy()
    all_labels = all_labels.numpy()

    task_aucs = []
    task_prs = []
    for i, task in enumerate(tasks):
        y_true = all_labels[:, i]
        y_prob = all_probs[:, i]
        valid_mask = (y_true != -1.0)

        y_true_valid = y_true[valid_mask]
        y_prob_valid = y_prob[valid_mask]

        # Need both classes present to compute AUC
        if len(np.unique(y_true_valid)) < 2:
            task_aucs.append(np.nan)
            task_prs.append(np.nan)
            continue

        auc = roc_auc_score(y_true_valid, y_prob_valid)
        pr = average_precision_score(y_true_valid, y_prob_valid)
        task_aucs.append(auc)
        task_prs.append(pr)

    mean_auc = np.nanmean(task_aucs)
    mean_pr = np.nanmean(task_prs)

    return {
        'mean_auc': mean_auc,
        'mean_pr': mean_pr,
        'task_aucs': dict(zip(tasks, task_aucs)),
        'task_prs': dict(zip(tasks, task_prs))
    }


