# CELL 14 - Purpose: Run GNNExplainer on all K=10 variants, realign attributions to original atom indexing, compute ACS

def get_node_importance(mol, model, task_idx, device, epochs=200):
    """Run GNNExplainer on a single RDKit mol and return per-atom importance scores."""
    data = mol_to_pyg_data(mol).to(device)

    wrapped = SingleGraphWrapper(model, task_idx).to(device)
    wrapped.eval()

    exp = Explainer(
        model=wrapped,
        algorithm=GNNExplainer(epochs=epochs),
        explanation_type='model',
        node_mask_type='attributes',
        edge_mask_type='object',
        model_config=dict(mode='regression', task_level='graph', return_type='raw'),
    )
    explanation = exp(data.x, data.edge_index)
    importance = explanation.node_mask.sum(dim=1).cpu().detach().numpy()
    return importance


def realign_to_original_order(importance, perm):
    """
    importance[i] corresponds to atom at position i in the VARIANT.
    perm[i] tells us which ORIGINAL atom index that variant-position i came from.
    So original_importance[perm[i]] = importance[i].
    """
    n = len(perm)
    realigned = np.zeros(n)
    for variant_pos, original_idx in enumerate(perm):
        realigned[original_idx] = importance[variant_pos]
    return realigned


print("Running GNNExplainer on all 10 variants (this takes a minute)...\n")
