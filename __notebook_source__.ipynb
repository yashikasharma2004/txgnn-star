# CELL 27 - Purpose: Load and preprocess ClinTox dataset for cross-dataset PBES/ERI validation

clintox_df = pd.read_csv('/kaggle/working/data/clintox.csv.gz')
print(f"ClinTox raw shape: {clintox_df.shape}")
print(f"Columns: {list(clintox_df.columns)}")

clintox_df = clintox_df.dropna(subset=['smiles']).reset_index(drop=True)
valid_mask_ct = clintox_df['smiles'].apply(is_valid_smiles)
print(f"\nDropping {(~valid_mask_ct).sum()} unparseable SMILES out of {len(clintox_df)}")
clintox_df = clintox_df[valid_mask_ct].reset_index(drop=True)

print(f"\n✅ ClinTox cleaned shape: {clintox_df.shape}")
print(f"\nSample rows:")
print(clintox_df.head())

# Sample a subset for PBES/ERI cross-validation (keep it manageable, e.g. 40 molecules)
N_CLINTOX_SAMPLE = 40
np.random.seed(777)
clintox_sample_idx = np.random.choice(len(clintox_df), size=N_CLINTOX_SAMPLE, replace=False)
clintox_sample_smiles = clintox_df.iloc[clintox_sample_idx]['smiles'].tolist()

print(f"\n✅ Sampled {len(clintox_sample_smiles)} ClinTox molecules for cross-dataset PBES validation")


# CELL 28 - Purpose: Run full PBES (ACS) + SSS + TAS pipeline on ClinTox sample molecules for cross-dataset validation

import time

print(f"Running cross-dataset validation on {len(clintox_sample_smiles)} ClinTox molecules...\n")
clintox_results = []
overall_start = time.time()

for count, smi in enumerate(clintox_sample_smiles):
    mol_start = time.time()
    mol = Chem.MolFromSmiles(smi)

    try:
        acs, attrs, success = compute_pbes_acs(smi, model, TASK_IDX, DEVICE, K=10, gnn_epochs=200)
        sss = compute_sss_for_molecule(smi, model, TASK_IDX, DEVICE, epochs=200)
        importance = get_node_importance(mol, model, TASK_IDX, DEVICE, epochs=200)
        tas, matched_alerts = compute_tas(smi, importance, top_k_frac=0.25)
    except Exception as e:
        acs, sss, tas, matched_alerts, success = None, None, None, [], False
        print(f"  [{count+1}/{len(clintox_sample_smiles)}] ERROR: {e}")

    mol_time = time.time() - mol_start
    n_atoms = mol.GetNumAtoms() if mol is not None else 0

    clintox_results.append({
        'smiles': smi,
        'n_atoms': n_atoms,
        'acs': float(acs) if acs is not None else None,
        'sss': float(sss) if sss is not None else None,
        'tas': float(tas) if tas is not None else None,
        'n_matched_alerts': len(matched_alerts),
        'success': success,
        'time_sec': mol_time
    })

    if (count + 1) % 10 == 0:
        elapsed = time.time() - overall_start
        remaining = (elapsed / (count + 1)) * (len(clintox_sample_smiles) - count - 1)
        print(f"  [{count+1}/{len(clintox_sample_smiles)}] Done. Elapsed: {elapsed/60:.1f} min | "
              f"Est. remaining: {remaining/60:.1f} min")

total_elapsed = time.time() - overall_start
print(f"\n✅ ClinTox cross-dataset validation complete!")
print(f"✅ Total time: {total_elapsed/60:.1f} minutes")
print(f"✅ Successful: {sum(r['success'] for r in clintox_results)}/{len(clintox_sample_smiles)}")

clintox_results_df = pd.DataFrame(clintox_results)
clintox_results_df.to_json('/kaggle/working/clintox_validation_results.json', orient='records', indent=2)
print(f"✅ Results saved to clintox_validation_results.json")


# CELL 29 - Purpose: Compare Tox21 (in-domain) vs ClinTox (cross-dataset) PBES/SSS results to test generalization

with open('/kaggle/working/clintox_validation_results.json', 'r') as f:
    clintox_results = json.load(f)

clintox_df_results = pd.DataFrame(clintox_results)
clintox_valid = clintox_df_results[clintox_df_results['success'] == True].copy()

print(f"--- Tox21 (n={len(combined_df)}) vs ClinTox (n={len(clintox_valid)}) ---\n")

print("ACS comparison:")
print(f"  Tox21   -> mean={combined_df['acs'].mean():.4f}, std={combined_df['acs'].std():.4f}, "
      f"median={combined_df['acs'].median():.4f}")
print(f"  ClinTox -> mean={clintox_valid['acs'].mean():.4f}, std={clintox_valid['acs'].std():.4f}, "
      f"median={clintox_valid['acs'].median():.4f}")

print("\nSSS comparison:")
print(f"  Tox21   -> mean={combined_df['sss'].mean():.4f}, std={combined_df['sss'].std():.4f}")
print(f"  ClinTox -> mean={clintox_valid['sss'].mean():.4f}, std={clintox_valid['sss'].std():.4f}")

clintox_tas_valid = clintox_valid[clintox_valid['tas'].notna()]
print(f"\nTAS comparison:")
print(f"  Tox21   -> {combined_df['tas'].notna().sum()}/{len(combined_df)} molecules had alert matches, "
      f"mean TAS (where defined) = {combined_df['tas'].mean():.4f}")
print(f"  ClinTox -> {len(clintox_tas_valid)}/{len(clintox_valid)} molecules had alert matches, "
      f"mean TAS (where defined) = {clintox_tas_valid['tas'].mean() if len(clintox_tas_valid) > 0 else float('nan'):.4f}")

# Statistical test: is the ACS distribution significantly different between datasets?
from scipy.stats import mannwhitneyu
stat, p_value = mannwhitneyu(combined_df['acs'], clintox_valid['acs'], alternative='two-sided')
print(f"\n--- Mann-Whitney U test (ACS: Tox21 vs ClinTox) ---")
print(f"U statistic = {stat:.2f}, p-value = {p_value:.4f}")
if p_value < 0.05:
    print("=> Statistically significant difference in explanation stability between datasets")
else:
    print("=> No statistically significant difference - PBES generalizes consistently across datasets")

# Visualization
fig, axes = plt.subplots(1, 2, figsize=(13, 5))

axes[0].hist(combined_df['acs'], bins=15, alpha=0.6, label='Tox21 (in-domain)', color='steelblue', density=True)
axes[0].hist(clintox_valid['acs'], bins=15, alpha=0.6, label='ClinTox (cross-dataset)', color='darkorange', density=True)
axes[0].set_xlabel('ACS')
axes[0].set_ylabel('Density')
axes[0].set_title('ACS Distribution: Tox21 vs ClinTox')
axes[0].legend()
axes[0].grid(alpha=0.3)

axes[1].boxplot([combined_df['acs'], clintox_valid['acs']], labels=['Tox21', 'ClinTox'])
axes[1].set_ylabel('ACS')
axes[1].set_title('ACS Boxplot Comparison')
axes[1].grid(alpha=0.3)

plt.tight_layout()
plt.savefig('/kaggle/working/clintox_cross_validation.png', dpi=150)
plt.show()

print(f"\n✅ Cross-dataset comparison saved!")


