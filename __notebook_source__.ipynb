# CELL 7 - Purpose: Define masked BCE loss (handles missing Tox21 labels marked as -1) + optimizer + LR scheduler

def masked_bce_loss(logits, labels):
    """
    Tox21 has missing assay results marked as -1.
    This loss ignores those positions and only computes BCE on valid (0/1) labels.
    """
    mask = (labels != -1.0).float()
    # Avoid log(0) issues: BCEWithLogitsLoss is numerically stable with raw logits
    loss_fn = nn.BCEWithLogitsLoss(reduction='none')
    raw_loss = loss_fn(logits, labels.clamp(min=0))  # clamp -1 -> 0 just to avoid invalid target warnings; masked out anyway
    masked_loss = raw_loss * mask
    # Average only over valid entries
    return masked_loss.sum() / mask.sum().clamp(min=1.0)


