# CELL 21 - Purpose: Define curated structural alert SMARTS patterns (Kazius et al. 2005 style, ToxAlerts-consistent)
# and compute Toxicophore Agreement Score (TAS) = does the model's explanation overlap with known toxic substructures?

# Curated structural alerts - well-known toxicophores/mutagenicity alerts from literature (Kazius et al., 2005; 
# consistent with patterns aggregated in ToxAlerts, Sushko et al., 2012)
STRUCTURAL_ALERTS = {
    'nitro_aromatic': '[$([NX3](=O)=O)]c',
    'aromatic_amine': 'c[NX3;H2,H1;!$(NC=O)]',
    'aromatic_nitroso': 'c[N]=O',
    'azo_group': '[#6]N=N[#6]',
    'epoxide': 'C1OC1',
    'aziridine': 'C1NC1',
    'alkyl_halide': '[CX4][Cl,Br,I]',
    'acyl_halide': 'C(=O)[Cl,Br,I,F]',
    'aldehyde': '[CX3H1](=O)[#6]',
    'michael_acceptor_enone': 'C=CC(=O)',
    'quinone': 'O=C1C=CC(=O)C=C1',
    'hydrazine': '[NX3][NX3]',
    'nitrosamine': '[#7][N]=O',
    'polycyclic_aromatic': 'c1ccc2ccccc2c1',
    'thiourea': '[#7]C(=S)[#7]',
    'isocyanate': '[N]=C=O',
    'sulfonate_ester': 'OS(=O)(=O)O',
    'alkyl_sulfonate': '[CX4]S(=O)(=O)O',
    'nitrile': 'C#N',
    'aromatic_nitro': 'c[N+](=O)[O-]',
    'haloalkene': 'C=C[Cl,Br,I,F]',
    'beta_lactam': 'C1C(=O)N1',
    'carbamate': '[#7]C(=O)O',
    'peroxide': '[#8][#8]',
    'aromatic_azide': 'cN=[N+]=[N-]',
    'diazo': '[CX3]=[N+]=[N-]',
    'thioamide': '[#7]C(=S)',
    'imine': '[CX3]=[NX2]',
    'organophosphate': 'P(=O)(O)(O)O',
    'vinyl_halide': 'C=C[F,Cl,Br,I]',
}

# Pre-compile SMARTS patterns once (faster, and lets us know if any are invalid)
compiled_alerts = {}
for name, smarts in STRUCTURAL_ALERTS.items():
    patt = Chem.MolFromSmarts(smarts)
    if patt is not None:
        compiled_alerts[name] = patt
    else:
        print(f"⚠️ Invalid SMARTS skipped: {name}")

print(f"✅ Compiled {len(compiled_alerts)} structural alert patterns")


def get_alert_atoms(mol):
    """Return the set of atom indices that match ANY known structural alert."""
    alert_atom_indices = set()
    matched_alerts = []
    for name, patt in compiled_alerts.items():
        matches = mol.GetSubstructMatches(patt)
        if matches:
            matched_alerts.append(name)
            for match in matches:
                alert_atom_indices.update(match)
    return alert_atom_indices, matched_alerts


def compute_tas(smiles, node_importance, top_k_frac=0.25):
    """
    Toxicophore Agreement Score (TAS):
    Take the top-K most important atoms from the model's explanation,
    check what fraction of them overlap with atoms in known structural alerts.

    TAS = |top-important-atoms ∩ alert-atoms| / |top-important-atoms|
    Returns None if molecule has no matching alerts at all (undefined agreement).
    """
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None, []

    alert_atoms, matched_alerts = get_alert_atoms(mol)
    n_atoms = mol.GetNumAtoms()

    if len(alert_atoms) == 0:
        return None, matched_alerts  # no known toxicophore present - TAS undefined for this molecule

    top_k = max(1, int(np.ceil(n_atoms * top_k_frac)))
    top_important_indices = set(np.argsort(node_importance)[-top_k:])

    overlap = len(top_important_indices & alert_atoms)
    tas = overlap / len(top_important_indices)
    return tas, matched_alerts


