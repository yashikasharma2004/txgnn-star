# CELL 12 - Purpose: Set up PyTorch Geometric's GNNExplainer and test it on a single molecule to get atom attribution scores

from torch_geometric.explain import Explainer, GNNExplainer

# GNNExplainer needs a model wrapper that handles single-graph (no batch) forward pass
class SingleGraphWrapper(nn.Module):
    """Wraps the trained GAT model so GNNExplainer can call it on one graph at a time
    (no batch vector needed since it's always a single graph)."""
    def __init__(self, base_model, task_idx):
        super().__init__()
        self.base_model = base_model
        self.task_idx = task_idx  # which of the 12 toxicity tasks to explain

    def forward(self, x, edge_index):
        batch = torch.zeros(x.size(0), dtype=torch.long, device=x.device)
        out = self.base_model(x, edge_index, batch)
        return out[:, self.task_idx:self.task_idx+1]  # explainer expects single output per graph


# Pick a sample molecule from test set to explain (e.g. NR-AhR task, index 2)
TASK_IDX = 2  # NR-AhR - one of the stronger-performing tasks
sample_graph = test_graphs[0].to(DEVICE)

wrapped_model = SingleGraphWrapper(model, TASK_IDX).to(DEVICE)
wrapped_model.eval()

explainer = Explainer(
    model=wrapped_model,
    algorithm=GNNExplainer(epochs=200),
    explanation_type='model',
    node_mask_type='attributes',
    edge_mask_type='object',
    model_config=dict(
        mode='regression',   # raw logit output, treated as regression target for explainer
        task_level='graph',
        return_type='raw',
    ),
)

explanation = explainer(sample_graph.x, sample_graph.edge_index)

# Aggregate node feature mask into a single per-atom importance score
node_importance = explanation.node_mask.sum(dim=1).cpu().detach().numpy()

