# ---- Feature functions (Cell 3) ----
def get_atom_features(atom):
    features = []
    atom_types = ['C', 'N', 'O', 'S', 'F', 'Si', 'P', 'Cl', 'Br', 'I', 'B', 'Other']
    symbol = atom.GetSymbol()
    features += [1 if symbol == t else 0 for t in atom_types[:-1]]
    features += [1 if symbol not in atom_types[:-1] else 0]
    features += [atom.GetDegree()]
    features += [atom.GetFormalCharge()]
    hybridizations = [Chem.rdchem.HybridizationType.SP,
                       Chem.rdchem.HybridizationType.SP2,
                       Chem.rdchem.HybridizationType.SP3]
    features += [1 if atom.GetHybridization() == h else 0 for h in hybridizations]
    features += [1 if atom.GetIsAromatic() else 0]
    features += [atom.GetTotalNumHs()]
    features += [1 if atom.IsInRing() else 0]
    features += [1 if atom.GetChiralTag() != Chem.rdchem.ChiralType.CHI_UNSPECIFIED else 0]
    return features

def get_bond_features(bond):
    bond_types = [Chem.rdchem.BondType.SINGLE, Chem.rdchem.BondType.DOUBLE,
                  Chem.rdchem.BondType.TRIPLE, Chem.rdchem.BondType.AROMATIC]
    features = [1 if bond.GetBondType() == bt else 0 for bt in bond_types]
    features += [1 if bond.GetIsConjugated() else 0]
    features += [1 if bond.IsInRing() else 0]
    return features

def smiles_to_graph(smiles, labels=None):
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None
    atom_features = [get_atom_features(atom) for atom in mol.GetAtoms()]
    if len(atom_features) == 0:
        return None
    x = torch.tensor(atom_features, dtype=torch.float)
    edge_indices, edge_features = [], []
    for bond in mol.GetBonds():
        i, j = bond.GetBeginAtomIdx(), bond.GetEndAtomIdx()
        bf = get_bond_features(bond)
        edge_indices += [[i, j], [j, i]]
        edge_features += [bf, bf]
    if len(edge_indices) == 0:
        edge_indices = [[0, 0]]
        edge_features = [[0, 0, 0, 0, 0, 0]]
    edge_index = torch.tensor(edge_indices, dtype=torch.long).t().contiguous()
    edge_attr = torch.tensor(edge_features, dtype=torch.float)
    data = Data(x=x, edge_index=edge_index, edge_attr=edge_attr)
    data.smiles = smiles
    if labels is not None:
        data.y = torch.tensor(labels, dtype=torch.float).unsqueeze(0)
    return data

NUM_ATOM_FEATURES = len(get_atom_features(Chem.MolFromSmiles('CCO').GetAtomWithIdx(0)))

# ---- Scaffold split functions (Cell 4) ----
from collections import defaultdict

def get_scaffold(smiles):
    try:
        mol = Chem.MolFromSmiles(smiles)
        if mol is None:
            return None
        return MurckoScaffold.MurckoScaffoldSmiles(mol=mol, includeChirality=False)
    except:
        return None

def scaffold_split(df, smiles_col='smiles', frac_train=0.8, frac_valid=0.1, frac_test=0.1, seed=42):
    scaffolds = defaultdict(list)
    for idx, smiles in enumerate(df[smiles_col]):
        scaffold = get_scaffold(smiles)
        if scaffold is not None:
            scaffolds[scaffold].append(idx)
    scaffold_sets = sorted(scaffolds.values(), key=lambda x: len(x), reverse=True)
    rng = np.random.RandomState(seed)
    scaffold_sets = sorted(scaffold_sets, key=lambda x: (-len(x), rng.random()))
    n_total = sum(len(s) for s in scaffold_sets)
    train_target = frac_train * n_total
    valid_target = frac_valid * n_total
    test_target = frac_test * n_total
    train_idx, valid_idx, test_idx = [], [], []
    for s in scaffold_sets:
        train_def = train_target - len(train_idx)
        valid_def = valid_target - len(valid_idx)
        test_def = test_target - len(test_idx)
        choice = max([('train', train_def), ('valid', valid_def), ('test', test_def)], key=lambda x: x[1])[0]
        if choice == 'train': train_idx += s
        elif choice == 'valid': valid_idx += s
        else: test_idx += s
    return train_idx, valid_idx, test_idx

def is_valid_smiles(smiles):
    return Chem.MolFromSmiles(smiles) is not None

def df_to_graphs(df, indices, tasks):
    graphs = []
    for idx in indices:
        row = df.iloc[idx]
        smiles = row['smiles']
        labels = [(-1.0 if pd.isna(row[t]) else float(row[t])) for t in tasks]
        graph = smiles_to_graph(smiles, labels=labels)
        if graph is None or graph.x.shape[0] == 0:
            continue
        graphs.append(graph)
    return graphs

