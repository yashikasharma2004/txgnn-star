for i, (perm, mol) in enumerate(variants):
    imp = get_node_importance(mol, model, TASK_IDX, DEVICE, epochs=200)
    realigned = realign_to_original_order(imp, perm)
    realigned_attributions.append(realigned)
    print(f"  Variant {i} done. Importance range: [{imp.min():.4f}, {imp.max():.4f}]")

realigned_attributions = np.array(realigned_attributions)  # shape: (K, n_atoms)
print(f"\n✅ All variants processed. Attribution matrix shape: {realigned_attributions.shape}")

# Compute ACS: mean pairwise Spearman rank correlation across all K explanations
K = realigned_attributions.shape[0]
correlations = []
for i in range(K):
    for j in range(i + 1, K):
        rho, _ = spearmanr(realigned_attributions[i], realigned_attributions[j])
        correlations.append(rho)

ACS = np.mean(correlations)
print(f"\n✅ Number of pairwise comparisons: {len(correlations)}")
print(f"✅ Attribution Consistency Score (ACS) = {ACS:.4f}")
print(f"   (1.0 = perfectly stable explanation, 0.0 = random, negative = anti-correlated/unstable)")


# CELL 15 - Purpose: Wrap the full PBES pipeline (variants -> explain -> realign -> ACS) into one reusable function

def compute_pbes_acs(smiles, model, task_idx, device, K=10, gnn_epochs=100, seed=42):
    """
    Full PBES pipeline for a single molecule:
    1. Generate K graph-isomorphic variants
    2. Run GNNExplainer on each
    3. Realign attributions to original atom order
    4. Compute ACS (mean pairwise Spearman correlation)

    Returns: (ACS score, realigned_attributions matrix, success flag)
    """
    variants, attempts, fail_reasons, n_atoms = generate_isomorphic_variants(smiles, K=K, seed=seed)

    if len(variants) < 2 or n_atoms < 3:
        return None, None, False  # too small / failed to generate variants

    realigned_attributions = []
    for perm, mol in variants:
        try:
            imp = get_node_importance(mol, model, task_idx, device, epochs=gnn_epochs)
            realigned = realign_to_original_order(imp, perm)
            realigned_attributions.append(realigned)
        except Exception:
            continue

    if len(realigned_attributions) < 2:
        return None, None, False

    realigned_attributions = np.array(realigned_attributions)
    K_actual = realigned_attributions.shape[0]

    correlations = []
    for i in range(K_actual):
        for j in range(i + 1, K_actual):
            rho, _ = spearmanr(realigned_attributions[i], realigned_attributions[j])
            if not np.isnan(rho):
                correlations.append(rho)

    if len(correlations) == 0:
        return None, None, False

    acs = np.mean(correlations)
    return acs, realigned_attributions, True


