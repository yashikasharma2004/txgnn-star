# CELL 23 - Purpose: Compute the Explanation Reliability Index (ERI) combining ACS, SSS, TAS
# When TAS is undefined (no known structural alert), weights are re-normalized over the available components

# First, normalize ACS, SSS, TAS to comparable 0-1 scales using min-max scaling (since raw ranges differ a lot:
# ACS is already ~0-1, SSS is ~0.03-0.17, TAS is 0-1 but very sparse)

def minmax_normalize(series):
    s_min, s_max = series.min(), series.max()
    if s_max == s_min:
        return series * 0  # avoid divide by zero
    return (series - s_min) / (s_max - s_min)

combined_df['acs_norm'] = minmax_normalize(combined_df['acs'])
combined_df['sss_norm'] = minmax_normalize(combined_df['sss'])
# TAS is already 0-1 by construction, no normalization needed, but NaNs remain NaN

# Base weights (will be re-normalized per-row when TAS is missing)
ALPHA, BETA, GAMMA = 0.5, 0.2, 0.3  # ACS weighted highest (core stability signal), TAS second, SSS lowest

def compute_eri(row, alpha=ALPHA, beta=BETA, gamma=GAMMA):
    acs, sss, tas = row['acs_norm'], row['sss_norm'], row['tas']

    if pd.isna(tas):
        # Re-normalize weights over ACS and SSS only
        total_w = alpha + beta
        eri = (alpha / total_w) * acs + (beta / total_w) * sss
    else:
        eri = alpha * acs + beta * sss + gamma * tas

    return eri

combined_df['eri'] = combined_df.apply(compute_eri, axis=1)

