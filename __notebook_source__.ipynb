# CELL 24 - Purpose: Implement RGRT decision layer - classify each molecule's explanation into 
# Trust / Caveat / Mandatory Review tiers based on ERI, and compute HRPS = 1 - ERI for review prioritization

def assign_rgrt_tier(eri, trust_threshold=0.7, caveat_threshold=0.4):
    """
    Three-tier reliability-based decision rule:
    - Trust: ERI >= trust_threshold -> explanation is reliable, proceed without review
    - Caveat: caveat_threshold <= ERI < trust_threshold -> flag with warning, use with caution
    - Mandatory Review: ERI < caveat_threshold -> explanation is unreliable, requires expert review
    """
    if eri >= trust_threshold:
        return 'Trust'
    elif eri >= caveat_threshold:
        return 'Caveat'
    else:
        return 'Mandatory Review'


TRUST_THRESHOLD = 0.7
CAVEAT_THRESHOLD = 0.4

combined_df['rgrt_tier'] = combined_df['eri'].apply(
    lambda x: assign_rgrt_tier(x, TRUST_THRESHOLD, CAVEAT_THRESHOLD)
)
combined_df['hrps'] = 1 - combined_df['eri']  # Human Review Priority Score

print(f"✅ RGRT tiers assigned!")
print(f"\n--- Tier Distribution ---")
tier_counts = combined_df['rgrt_tier'].value_counts()
for tier in ['Trust', 'Caveat', 'Mandatory Review']:
    count = tier_counts.get(tier, 0)
    pct = count / len(combined_df) * 100
    print(f"{tier:<20}: {count:3d} molecules ({pct:.1f}%)")

print(f"\n--- HRPS Summary (higher = more urgent for expert review) ---")
