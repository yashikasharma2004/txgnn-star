def get_atom_features(atom):
    """Generate feature vector for a single atom"""
    features = []
    # Atomic number (one-hot for common atoms in Tox21)
    atom_types = ['C', 'N', 'O', 'S', 'F', 'Si', 'P', 'Cl', 'Br', 'I', 'B', 'Other']
    symbol = atom.GetSymbol()
    features += [1 if symbol == t else 0 for t in atom_types[:-1]]
    features += [1 if symbol not in atom_types[:-1] else 0]

    # Degree
    features += [atom.GetDegree()]
    # Formal charge
    features += [atom.GetFormalCharge()]
    # Hybridization
    hybridizations = [Chem.rdchem.HybridizationType.SP,
                       Chem.rdchem.HybridizationType.SP2,
                       Chem.rdchem.HybridizationType.SP3]
    features += [1 if atom.GetHybridization() == h else 0 for h in hybridizations]
    # Aromaticity
    features += [1 if atom.GetIsAromatic() else 0]
    # Total Hs
    features += [atom.GetTotalNumHs()]
    # In ring
    features += [1 if atom.IsInRing() else 0]
    # Chirality
    features += [1 if atom.GetChiralTag() != Chem.rdchem.ChiralType.CHI_UNSPECIFIED else 0]

    return features


def get_bond_features(bond):
    """Generate feature vector for a single bond"""
    bond_types = [Chem.rdchem.BondType.SINGLE,
                  Chem.rdchem.BondType.DOUBLE,
                  Chem.rdchem.BondType.TRIPLE,
                  Chem.rdchem.BondType.AROMATIC]
    features = [1 if bond.GetBondType() == bt else 0 for bt in bond_types]
    features += [1 if bond.GetIsConjugated() else 0]
    features += [1 if bond.IsInRing() else 0]
    return features


def smiles_to_graph(smiles, labels=None):
    """Convert a SMILES string into a PyG Data object"""
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None

    # Node features
    atom_features = [get_atom_features(atom) for atom in mol.GetAtoms()]
    if len(atom_features) == 0:
        return None
    x = torch.tensor(atom_features, dtype=torch.float)

    # Edge index + edge features
    edge_indices = []
    edge_features = []
    for bond in mol.GetBonds():
        i = bond.GetBeginAtomIdx()
        j = bond.GetEndAtomIdx()
        bf = get_bond_features(bond)
        edge_indices += [[i, j], [j, i]]
        edge_features += [bf, bf]

    if len(edge_indices) == 0:
        # Single atom molecule, add self loop
        edge_indices = [[0, 0]]
        edge_features = [[0, 0, 0, 0, 0, 0]]

    edge_index = torch.tensor(edge_indices, dtype=torch.long).t().contiguous()
    edge_attr = torch.tensor(edge_features, dtype=torch.float)

    data = Data(x=x, edge_index=edge_index, edge_attr=edge_attr)
    data.smiles = smiles

    if labels is not None:
        data.y = torch.tensor(labels, dtype=torch.float).unsqueeze(0)

    return data


