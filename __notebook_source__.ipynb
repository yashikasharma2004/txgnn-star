    history['val_pr'].append(val_pr)

    if val_auc > best_val_auc:
        best_val_auc = val_auc
        patience_counter = 0
        torch.save(model.state_dict(), best_model_path)
        marker = "  <-- best so far, saved"
    else:
        patience_counter += 1
        marker = ""

    if epoch % 1 == 0:
        current_lr = optimizer.param_groups[0]['lr']
        print(f"Epoch {epoch:3d} | Train Loss: {train_loss:.4f} | Val AUC: {val_auc:.4f} | "
              f"Val PR-AUC: {val_pr:.4f} | LR: {current_lr:.6f}{marker}")

    if patience_counter >= PATIENCE:
        print(f"\n⏹ Early stopping triggered at epoch {epoch} (no improvement for {PATIENCE} epochs)")
        break

