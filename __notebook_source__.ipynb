# CELL 6 - Purpose: Define 5-layer, 8-head Graph Attention Network (GAT) model for multi-task toxicity prediction

class GATToxicityModel(nn.Module):
    """5-layer, 8-head Graph Attention Network for multi-task toxicity prediction"""

    def __init__(self, num_node_features, num_tasks, hidden_dim=64, num_heads=8, num_layers=5, dropout=0.2):
        super(GATToxicityModel, self).__init__()

        self.num_layers = num_layers
        self.convs = nn.ModuleList()
        self.bns = nn.ModuleList()

        # First layer: input -> hidden
        self.convs.append(GATConv(num_node_features, hidden_dim, heads=num_heads, dropout=dropout, concat=True))
        self.bns.append(nn.BatchNorm1d(hidden_dim * num_heads))

        # Middle layers: hidden*heads -> hidden
        for _ in range(num_layers - 2):
            self.convs.append(GATConv(hidden_dim * num_heads, hidden_dim, heads=num_heads, dropout=dropout, concat=True))
            self.bns.append(nn.BatchNorm1d(hidden_dim * num_heads))

        # Last GAT layer: average heads instead of concat (stabilizes final representation)
        self.convs.append(GATConv(hidden_dim * num_heads, hidden_dim, heads=num_heads, dropout=dropout, concat=False))
        self.bns.append(nn.BatchNorm1d(hidden_dim))

        self.dropout = dropout

        # Readout: combine mean + max pooling
        self.fc1 = nn.Linear(hidden_dim * 2, hidden_dim)
        self.fc2 = nn.Linear(hidden_dim, num_tasks)

    def forward(self, x, edge_index, batch, return_attention=False):
        attentions = []
        for i in range(self.num_layers):
            if return_attention:
                x, (edge_idx, alpha) = self.convs[i](x, edge_index, return_attention_weights=True)
                attentions.append((edge_idx, alpha))
            else:
                x = self.convs[i](x, edge_index)
            x = self.bns[i](x)
            x = F.elu(x)
            x = F.dropout(x, p=self.dropout, training=self.training)

        x_mean = global_mean_pool(x, batch)
        x_max = global_max_pool(x, batch)
        x = torch.cat([x_mean, x_max], dim=1)

        x = F.elu(self.fc1(x))
        x = F.dropout(x, p=self.dropout, training=self.training)
        out = self.fc2(x)   # raw logits, sigmoid applied later via BCEWithLogitsLoss

        if return_attention:
            return out, attentions
        return out


