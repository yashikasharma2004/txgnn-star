# CELL 19 - Purpose: Implement Structural Sparsity Score (SSS) using Gini coefficient of atom attribution scores
# Intuition: a "sparse" explanation highlights a few key atoms strongly (high Gini = more interpretable for chemists);
# a "diffuse" explanation spreads importance thinly across all atoms (low Gini = harder to act on)

def gini_coefficient(values):
    """
    Compute the Gini coefficient of a non-negative array.
    0 = perfectly equal (every atom equally important, uninformative)
    1 = perfectly concentrated (one atom has all the importance, maximally sparse)
    """
    values = np.array(values, dtype=np.float64)
    values = np.abs(values)  # importance scores should be non-negative; safeguard
    if values.sum() == 0:
        return 0.0
    sorted_vals = np.sort(values)
    n = len(values)
    cumulative = np.cumsum(sorted_vals)
    gini = (2 * np.sum((np.arange(1, n + 1)) * sorted_vals) - (n + 1) * cumulative[-1]) / (n * cumulative[-1])
    return gini


def compute_sss_for_molecule(smiles, model, task_idx, device, epochs=200):
    """
    Compute SSS for a single molecule using the ORIGINAL (non-perturbed) atom ordering.
    Uses the same explainer call as PBES variant 0, so we reuse get_node_importance directly.
    """
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None
    importance = get_node_importance(mol, model, task_idx, device, epochs=epochs)
    sss = gini_coefficient(importance)
    return sss


